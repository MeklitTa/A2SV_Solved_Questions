class Solution:
    def shipWithinDays(self, weights, days):
        def can_ship(capacity):
            d = 1
            current = 0
            
            for w in weights:
                if current + w > capacity:
                    d += 1
                    current = 0
                current += w
            
            return d <= days
        
        left, right = max(weights), sum(weights)
        
        while left < right:
            mid = (left + right) // 2
            
            if can_ship(mid):
                right = mid
            else:
                left = mid + 1
        
        return left
