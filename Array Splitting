import sys
input = sys.stdin.readline

n, k = map(int, input().split())
a = list(map(int, input().split()))
if k == 1:
    print(a[-1] - a[0])
else:
    diffs = [a[i] - a[i-1] for i in range(1, n)]
    diffs.sort(reverse=True)
    total_range = a[-1] - a[0]
    cost = total_range - sum(diffs[:k-1])
    
    print(cost)
