def min_repaints(n, k, stripe):
    whites = stripe[:k].count('W')
    min_whites = whites
    for i in range(k, n):
        if stripe[i - k] == 'W':
            whites -= 1

        if stripe[i] == 'W':
            whites += 1
        min_whites = min(min_whites, whites)

    return min_whites
t = int(input())
results = []

for _ in range(t):
    n, k = map(int, input().split())
    stripe = input().strip()
    results.append(min_repaints(n, k, stripe))

# Print results for all test cases
for res in results:
    print(res)
