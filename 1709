import sys
input = sys.stdin.readline

t = int(input())
for _ in range(t):
    n = int(input())
    a = list(map(int, input().split()))
    b = list(map(int, input().split()))
    
    ops = []
    
    for i in range(n):
        for j in range(n):
            if a[j] >= b[j]:
                a[j], b[j] = b[j], a[j]
                ops.append((3, j+1))
            if j < n-1 and a[j] >= a[j+1]:
                a[j], a[j+1] = a[j+1], a[j]
                ops.append((1, j+1))
            if j < n-1 and b[j] >= b[j+1]:
                b[j], b[j+1] = b[j+1], b[j]
                ops.append((2, j+1))
    
    print(len(ops))
    for op in ops:
        print(op[0], op[1])
