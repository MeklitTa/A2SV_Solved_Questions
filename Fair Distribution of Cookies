class Solution:
    def distributeCookies(self, cookies, k):
        n = len(cookies)
        dist = [0] * k
        res = float('inf')

        def backtrack(i):
            nonlocal res
            if i == n:
                res = min(res, max(dist))
                return
            
            for j in range(k):
                dist[j] += cookies[i]
                if dist[j] < res:
                    backtrack(i + 1)
                
                dist[j] -= cookies[i]
                if dist[j] == 0:
                    break

        backtrack(0)
        return res
