class Solution:
    def findErrorNums(self, nums):
        n = len(nums)
        seen = set()
        duplicate = -1
        
        for x in nums:
            if x in seen:
                duplicate = x
            seen.add(x)
        
        total = n * (n + 1) // 2
        actual_sum = sum(nums)
        
        missing = total - (actual_sum - duplicate)
        
        return [duplicate, missing]
