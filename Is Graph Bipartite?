class Solution:
    def isBipartite(self, graph):
        n = len(graph)
        color = [-1] * n  

        for start in range(n):
            if color[start] != -1:
                continue

            stack = [start]
            color[start] = 0

            while stack:
                node = stack.pop()

                for nei in graph[node]:
                    if color[nei] == -1:
                        color[nei] = 1 - color[node]
                        stack.append(nei)
                    elif color[nei] == color[node]:
                        return False

        return True
