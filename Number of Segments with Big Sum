
import sys

def main():
    data = list(map(int, sys.stdin.read().split()))
    n, s = data[0], data[1]
    a = data[2:]

    left = 0
    curr_sum = 0
    ans = 0

    for right in range(n):
        curr_sum += a[right]
        while curr_sum >= s:
            ans += n - right
            curr_sum -= a[left]
            left += 1

    print(ans)

if __name__ == "__main__":
    main()
