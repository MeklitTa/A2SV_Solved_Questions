t = int(input())
for _ in range(t):
    n = int(input())
    p = list(map(int, input().split()))

    res = [p[0]]  # always include first element

    for i in range(1, n - 1):
        # include if it's a local peak or valley
        if (p[i] > p[i-1] and p[i] > p[i+1]) or (p[i] < p[i-1] and p[i] < p[i+1]):
            res.append(p[i])

    res.append(p[-1])  # always include last element

    print(len(res))
    print(*res)
