import sys
input = sys.stdin.readline

t = int(input())
for _ in range(t):
    n = int(input())
    r = list(map(int, input().split()))
    m = int(input())
    b = list(map(int, input().split()))
    
    s = 0
    mr = 0
    for x in r:
        s += x
        mr = max(mr, s)
        
    s = 0
    mb = 0
    for x in b:
        s += x
        mb = max(mb, s)
        
    print(mr + mb)
