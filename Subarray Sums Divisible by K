from collections import defaultdict

class Solution:
    def subarraysDivByK(self, nums, k):
        count = defaultdict(int)
        count[0] = 1 
        prefix = 0
        res = 0

        for num in nums:
            prefix = (prefix + num) % k
            prefix = (prefix + k) % k
            res += count[prefix]
            count[prefix] += 1

        return res
