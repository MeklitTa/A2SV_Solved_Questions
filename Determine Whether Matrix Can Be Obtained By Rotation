class Solution:
    def findRotation(self, mat: List[List[int]], target: List[List[int]]) -> bool:
        
        def rotate(matrix):
            # Rotate 90 degrees clockwise
            return [list(row) for row in zip(*matrix[::-1])]
        
        for _ in range(4):  # Try 0°, 90°, 180°, 270°
            if mat == target:
                return True
            mat = rotate(mat)
        
        return False
